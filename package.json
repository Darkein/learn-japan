{
  "name": "learn-japan",
  "version": "0.0.0",
  "private": true,
  "description": "Lecteur de japonais extensif et adaptatif (PWA, local-first)",
  "workspaces": [
    "app",
    "worker"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app",
    "preview": "npm run preview -w app",
    "test": "npm run test -w app",
    "worker:dev": "npm run dev -w worker",
    "worker:deploy": "npm run deploy -w worker",
    "data:inventory": "tsx scripts/build-inventory.ts",
    "data:jmdict": "tsx scripts/build-jmdict.ts",
    "curriculum:check": "tsx scripts/check-curriculum.ts",
    "content:batch": "tsx scripts/pregenerate.ts",
    "data:examples": "tsx scripts/build-examples.ts",
    "data:mnemonics": "tsx scripts/build-mnemonics.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}

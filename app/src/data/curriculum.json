          { "ja": "勉強", "yomi": "べんきょう", "fr": "étude" },
          { "ja": "する", "fr": "faire" }
        ],
        "kanji": [
          { "ja": "私", "fr": "je, moi" },
          { "ja": "日", "fr": "jour, soleil" },
          { "ja": "本", "fr": "origine, livre" },
          { "ja": "語", "fr": "langue, parole" },
          { "ja": "勉", "fr": "effort, application" },
          { "ja": "強", "fr": "fort" }
        ],
        "grammar": ["nom + する — former un verbe", "は — particule de thème"]
      },
      "seed": {
        "intro": "Beaucoup de verbes japonais se construisent avec un nom + **する** (faire) : **勉強する** (« faire de l'étude » = étudier), **話する** (« faire de la conversation »), etc.\n\n**私は日本語を勉強する** = « moi, le japonais, (j')étudie ». Le **私** (moi) est rare à l'oral — on l'omet souvent — mais il sert ici à montrer la structure.",
        "storyJa": "私は日本語を勉強する。"
      }
    },
